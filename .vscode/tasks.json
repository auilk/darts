{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Generate Project (Premake)",
            "type": "shell",
            "command": "premake5",
            "args": ["gmake2"],
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "make",
            "args": ["config=debug"],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "Generate Project (Premake)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "make",
            "args": ["config=release"],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "dependsOn": "Generate Project (Premake)",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run Debug",
            "type": "shell",
            "dependsOn": "Build Debug",
            "command": "${workspaceFolder}/build/bin/Debug/Darts",
            "problemMatcher": []
        },
        {
            "label": "Run Release",
            "type": "shell",
            "dependsOn": "Build Release",
            "command": "${workspaceFolder}/build/bin/Release/Darts",
            "problemMatcher": []
        }
    ]
}